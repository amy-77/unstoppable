{
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "models": {
        "moonshot/kimi-k2.6": {
          "alias": "Kimi"
        },
        "zai/glm-5.1": {
          "alias": "GLM"
        }
      },
      "model": {
        "primary": "zai/glm-5.1"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "replace-with-your-own-token"
    },
    "port": 18789,
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowInsecureAuth": false
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding"
  },
  "plugins": {
    "entries": {
      "moonshot": {
        "enabled": true
      },
      "zai": {
        "enabled": true
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "moonshot": {
        "baseUrl": "https://api.moonshot.cn/v1",
        "api": "openai-completions",
        "apiKey": "replace-with-your-own-api-key",
        "models": [
          {
            "id": "kimi-k2.6",
            "name": "Kimi K2.6",
            "reasoning": false,
            "input": [
              "text",
              "image"
            ],
            "contextWindow": 262144,
            "maxTokens": 262144
          }
        ]
      },
      "zai": {
        "baseUrl": "https://api.z.ai/api/paas/v4",
        "api": "openai-completions",
        "apiKey": "replace-with-your-own-api-key",
        "models": [
          {
            "id": "glm-5.1",
            "name": "GLM-5.1",
            "reasoning": true,
            "input": [
              "text"
            ],
            "contextWindow": 202800,
            "maxTokens": 131100
          }
        ]
      }
    }
  }
}
