# Example launch environment for a local OpenClaw gateway service.
# Do not store real secrets in this file inside Git.

export HOME="$HOME"
export NODE_EXTRA_CA_CERTS="/etc/ssl/cert.pem"
export NODE_USE_SYSTEM_CA="1"
export OPENCLAW_GATEWAY_PORT="18789"
export OPENCLAW_LAUNCHD_LABEL="ai.openclaw.gateway"
export OPENCLAW_SERVICE_KIND="gateway"
export OPENCLAW_SERVICE_MARKER="openclaw"
export PATH="/opt/homebrew/opt/node/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

